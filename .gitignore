# Cargo build / cache. `.cargo/config.toml` is intentional source; the
# rest under `.cargo/` is created by `CARGO_HOME=/workspace/.cargo` in
# the dev container and must NOT be committed.
/target/
**/target/
**/*.rs.bk
Cargo.lock.bak
.cargo/registry/
.cargo/git/
.cargo/.global-cache
.cargo/.package-cache*

# Docker-volume mountpoints (per `compose.yaml`)
.sccache/
.xwin-cache/

# Extracted release artifacts (the docker volume holds the canonical
# build output; `just windows-exe` copies the .exe here for Windows-side
# execution).
/dist/

# IDE
/.idea/
/.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# coverage
/coverage/
*.profraw
*.profdata
lcov.info

# bacon
.bacon-locations

# cargo-xwin scratch (MSVC SDK vendored cache)
/.xwin-cache/

# release-plz
/.release-plz/

# scratch / local
/tmp/
*.log

# secrets
.env
.env.local
